import numpy as np
import matplotlib.pyplot as plt
import matplotlib.animation as animation

# 1. Define the original shape (a star shape around the origin)
angles = np.linspace(0, 2 * np.pi, 11)
# Alternating radii to create star points
radii = np.array([1.0, 0.4] * 5 + [1.0])  
x_original = radii * np.cos(angles)
y_original = radii * np.sin(angles)

# 2. Set up the figure and axis
fig, ax = plt.subplots(figsize=(6, 6))
# Create an empty line object that we will update in the animation
line, = ax.plot([], [], 'r-', lw=2)  

# Finalize axis limits and styling
ax.set_xlim(-1.5, 1.5)
ax.set_ylim(-1.5, 1.5)
ax.set_aspect('equal')
ax.axis('off')  # Hide axis borders and ticks

# 3. Initialization function for the animation
def init():
    line.set_data([], [])
    return line,

# 4. Animation update function (calculates rotation per frame)
def update(frame):
    # Convert the current frame number to a rotation angle in radians
    theta = np.radians(frame)
    
    # Apply the 2D rotation matrix: 
    # x' = x*cos(θ) - y*sin(θ)
    # y' = x*sin(θ) + y*cos(θ)
    x_rotated = x_original * np.cos(theta) - y_original * np.sin(theta)
    y_rotated = x_original * np.sin(theta) + y_original * np.cos(theta)
    
    # Update the drawing with the new coordinates
    line.set_data(x_rotated, y_rotated)
    return line,

# 5. Create and run the animation
# frames=360 means a full 360-degree loop; interval=20 means 20ms between frames
ani = animation.FuncAnimation(
    fig, update, init_func=init, frames=360, interval=20, blit=True
)

plt.show()