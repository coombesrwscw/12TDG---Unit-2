import random
import numpy as np
import matplotlib.pyplot as plt
from matplotlib.animation import FuncAnimation


# Function to create and animate the spinning wheel
def animate_wheel(labels):
    slices = [1] * len(labels)

    fig, ax = plt.subplots(figsize=(8, 8))

    def update(frame):
        ax.clear()
        spin_speed = (10 + spin_repeats * 20) * np.exp (-frame / 60)  # Adjust (10+spin_repeats*10) value to change the speed of the spin - Adjust the exponential decay factor (-frame/100) to change how quickly the spin slows down
        # Draws the pie chart with the current frame as the starting angle
        ax.pie( 
            slices,
            labels=labels,
            startangle=frame*spin_speed,
            labeldistance=0.7,
            wedgeprops={"edgecolor": "black", "linewidth": 2}
        )

        ax.plot([0], [1], marker='v', markersize=20, color='red') # Fixed pointer at top of wheel

        ax.set_aspect('equal')
        ax.set_title(wheel_name) # Title - will eventually be user input

    # Animates the wheel - MAKE THIS SMOOTHER AND FASTER - will eventually be user input for starting the animation - will also need to be able to stop the animation and select the winning segment
    ani = FuncAnimation(
        fig,
        update,
        frames=range(360, int(360 * (spin_repeats - 2))),  # Adjust the number of frames based on the number of spins
        interval=10,
        if frame==0:
            def update(frame):
                ax.clear()
                spin_speed = (10 + spin_repeats * 20) * np.exp (-frame / 60)  # Adjust (10+spin_repeats*10) value to change the speed of the spin - Adjust the exponential decay factor (-frame/100) to change how quickly the spin slows down
                # Draws the pie chart with the current frame as the starting angle
                ax.pie( 
                    slices,
                    labels=labels,
                    startangle=frame*spin_speed,
                    labeldistance=0.7,
                    wedgeprops={"edgecolor": "black", "linewidth": 2}
                )
        repeat=False,
    )

    plt.show()

    return ani

# List of labels for the wheel segments - will eventually be user input (wheel ajustable to # of labels)
labels = [
    "option1",
    "option2",
    "option3",
    "option4",
    "option5",
    "option6",
    "option7",
    "option8",
]

wheel_name = "My Spinning Wheel (to be updated)"  # Title for the wheel - will eventually be user input

spin_repeats = random.uniform(3,4) # Number of times the wheel will spin - will eventually be random

animation = animate_wheel(labels)